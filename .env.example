# PostgreSQL Database (Neon)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Environment
NODE_ENV=development
PORT=3000

# API URL (for CORS in production)
VITE_API_URL=https://cci-planning-sync.vercel.app

# Sécurité — origine(s) autorisées pour CORS (séparées par virgule, laisser vide = tout autoriser)
# Exemple : CORS_ORIGINS=https://cci-planning-sync.vercel.app,https://klint-qa.vercel.app
CORS_ORIGINS=

# Clé secrète pour protéger /api/init-db (générer avec : openssl rand -hex 32)
INIT_SECRET=
